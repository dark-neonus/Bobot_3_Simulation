<?xml version="1.0"?>
<robot name="bobot3">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.060" ixy="0" ixz="0" iyy="0.040" iyz="0" izz="0.030"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.225" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.45"/>
      </geometry>
      <material name="chassis_blue">
        <color rgba="0.20 0.35 0.80 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.225" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.45"/>
      </geometry>
    </collision>
  </link>

  <link name="battery_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.80"/>
      <inertia ixx="0.0020" ixy="0" ixz="0" iyy="0.0016" iyz="0" izz="0.0022"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.05 0.09"/>
      </geometry>
      <material name="battery_black">
        <color rgba="0.12 0.12 0.12 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.05 0.09"/>
      </geometry>
    </collision>
  </link>

  <joint name="battery_slider_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="battery_link"/>
    <origin xyz="0 0 0.050" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.20" upper="0.12" effort="220" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.28"/>
      <inertia ixx="0.000270" ixy="0" ixz="0" iyy="0.000424" iyz="0" izz="0.000270"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.050"/>
      </geometry>
      <material name="wheel_gray">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.050"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.125 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.28"/>
      <inertia ixx="0.000270" ixy="0" ixz="0" iyy="0.000424" iyz="0" izz="0.000270"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.050"/>
      </geometry>
      <material name="wheel_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.050"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.125 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>
</robot>
